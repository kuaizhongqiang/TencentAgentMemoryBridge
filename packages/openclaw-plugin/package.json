{
  "name": "@tencent-agent-memory/openclaw-plugin",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "OpenClaw plugin bridging agent lifecycle hooks to TencentDB Agent Memory",
  "license": "MIT",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external openclaw",
    "dev": "tsup src/index.ts --format esm --watch",
    "test": "vitest run"
  },
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "manifest": "./openclaw.plugin.json"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
