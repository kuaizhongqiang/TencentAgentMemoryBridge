{
  "name": "@tencent-agent-memory/mcp-bridge",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server bridging AI agents to TencentDB Agent Memory",
  "license": "MIT",
  "bin": {
    "mcp-bridge": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --watch --onSuccess 'node dist/index.js'",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
