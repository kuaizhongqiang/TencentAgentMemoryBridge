# Bridge Server configuration
PORT=3000

# TencentDB Agent Memory Gateway URL (internal network)
TENCENTDB_URL=http://localhost:8080

# Agent whitelist — option 1: JSON file path (recommended)
# File should contain a JSON array of agent objects.
AGENTS_FILE=./agents.json

# Agent whitelist — option 2: inline JSON (alternative to AGENTS_FILE)
# Each agent has: name, apiKeyHash (sha256 of the API key), allowedEndpoints
# AGENTS=[{"name":"codebuddy","apiKeyHash":"<sha256>","allowedEndpoints":["recall","capture","search/memories"]}]
