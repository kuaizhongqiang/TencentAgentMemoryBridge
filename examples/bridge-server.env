# Bridge Server configuration
PORT=3000

# TencentDB Agent Memory Gateway URL (internal network)
TENCENTDB_URL=http://localhost:8080

# Agent whitelist config (JSON)
# Each agent has: name, apiKeyHash (sha256 of the API key), allowedEndpoints
AGENTS=[{"name":"codebuddy","apiKeyHash":"<sha256-of-sk-codebuddy-key>","allowedEndpoints":["recall","capture","search/memories"]},{"name":"claude-code","apiKeyHash":"<sha256-of-sk-claude-code-key>","allowedEndpoints":["recall","capture","search/memories","search/conversations","session/end"]},{"name":"openclaw","apiKeyHash":"<sha256-of-sk-openclaw-key>","allowedEndpoints":["recall","capture","session/end"]}]
